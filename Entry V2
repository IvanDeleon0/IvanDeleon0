

#include <iostream>
using namespace std;
#include <chrono>
#include <thread>

void main_menu() {
    cout << "Welcome to the Accounting 101\n";
    cout << "============================\n";
    cout << "What is your First Entry?\n";
    cout << "1. Asset\n";
    cout << "2. Liabilities\n";
    cout << "3. Equity / Capital\n";
    cout << "4. Expense\n";
    cout << "5. Revenue\n";
    cout << "6. Exit\n";
    cout << "============================\n";
}

void endPrint(double origAmount) {
    if(origAmount == 0){
     cout << "You're Account have no enough funds";
    }else
    cout << "You're money left is "<< origAmount<<endl<<endl;
}

//animation
void loading(){
    for (int i = 1; i< 5;i++){
        cout <<".";
        this_thread::sleep_for(chrono::milliseconds(450));
    }
    cout<<endl;

}
int main() {
    int number = 0;
    double origAmount = 0;// initial // all uses origAmount
    double creditAmount = 0;//total credit amount
    double debitAmount = 0;//total debit amount
    double debitExpense = 0, creditExpense=0; //expense
    double debitAsset = 0, creditAsset=0; //asset
    double debitLiability = 0, creditLiability=0;// liability
    double debitRevenue =0, creditRevenue=0;//revenue
    double debitEquity =0, creditEquity=0;//revenue
    string entry;
   // I need debit'element'Amount like debitAssetAmount 

    while (number != 6) {

        main_menu();
        cout << "answer: ";
        cin >> number;

        switch (number) {

        case 1: { // ASSET
            cout << "\nYou've chose Asset Entry\n";
            cout << "[Debit]/[Credit] ? ";
            cin >> entry;
            loading();//animation

            if (entry == "debit" || entry == "Debit" || entry == "DEBIT") {
                cout << "Amount: ";
                cin >> debitAsset;
                origAmount += debitAsset;
            } else {
                cout << "Amount: ";
                cin >> creditAsset;
                origAmount -= creditAsset;
            }
            break;
        }

        case 2: { // LIABILITY
            cout << "\nYou've chose Liability Entry\n";
            cout << "[Debit]/[Credit] ? ";
            cin >> entry;
            loading();

            if (entry == "debit" || entry == "Debit" || entry == "DEBIT") {
                cout << "Amount: ";
                cin >> debitLiability;
                origAmount -= debitLiability;
            } else {
                cout << "Amount: ";
                cin >> creditLiability;
                origAmount += creditLiability;
            }
            break;
        }

        case 3: { // EQUITY / CAPITAL
            cout << "\nYou've chose Equity / Capital Entry\n";
            cout << "[Debit]/[Credit] ? ";
            cin >> entry;
            loading();

            if (entry == "debit" || entry == "Debit" || entry == "DEBIT") {
                cout << "Amount: ";
                cin >> debitEquity;
                origAmount -= debitEquity;
            } else {
                cout << "Amount: ";
                cin >> creditEquity;
                origAmount += creditEquity;
            }
            break;
        }

        case 4: { // EXPENSE
            cout << "\nYou've chose Expense Entry\n";
            cout << "[Debit]/[Credit] ? ";
            cin >> entry; 
            loading();

            if (entry == "debit" || entry == "Debit" || entry == "DEBIT") {
                cout << "Amount: ";
                cin >> debitExpense;
                origAmount += debitExpense;
            } else {
                cout << "Amount: ";
                cin >> creditExpense;
                origAmount -= creditExpense;
            }
            break;
        }

        case 5: { // REVENUE
            cout << "\nYou've chose Revenue Entry\n";
            cout << "[Debit]/[Credit] ? ";
            cin >> entry;
            loading();
            if (entry == "debit" || entry == "Debit" || entry == "DEBIT") {
                cout << "Amount: ";
                cin >> debitRevenue;
                origAmount += debitRevenue;
            } else {
                cout << "Amount: ";
                cin >> creditRevenue;
                origAmount -= creditRevenue;
            }
            break;
        }

        case 6:
            loading();
            cout << "Exiting program...\n";
            break;

        default:
            cout << "Invalid Number\n";
            break;
        }
    loading();
    endPrint (origAmount);
    loading();
    loading();
    cout<< "Program Closed";
    }

    return 0;
}

